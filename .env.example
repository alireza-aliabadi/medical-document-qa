# Application
APP_NAME=AI Medical Knowledge Assistant
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database
DATABASE_URL=postgresql+psycopg://medical:medical@localhost:5432/medical_kb

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=medical_chunks

# Object storage (MinIO / AIStor-compatible S3)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=medical-documents
S3_REGION=us-east-1

# Embeddings
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
USE_MOCK_EMBEDDINGS=true

# LLM / Inference
LLM_BASE_URL=http://localhost:8001/v1
LLM_MODEL=qwen3-1.7b
VLLM_BASE_URL=http://localhost:8001

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=medical-kb

# OpenTelemetry
OTEL_ENABLED=false
OTEL_SERVICE_NAME=medical-kb-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Auth
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
DEFAULT_ADMIN_EMAIL=admin@medical.local
DEFAULT_ADMIN_PASSWORD=changeme

# Rate limiting
RATE_LIMIT=100/minute
